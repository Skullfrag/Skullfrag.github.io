    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:ital,wght@0,400;0,600;0,700;1,700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
        /* Exact same styles as your main page to keep it consistent */
        :root {
            --gamer-red: #ff2a2a;
            --gamer-red-dark: #cc0000;
            --bg-base: #09090b;
            --bg-surface: #18181b;
            --text-main: #f4f4f5;
            --text-muted: #a1a1aa;
            --border-color: #27272a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            background-color: var(--bg-base); 
            color: var(--text-main); 
            font-family: 'Inter', sans-serif; 
            line-height: 1.6; 
            font-size: 1.05rem;
            background-image: radial-gradient(var(--border-color) 1px, transparent 1px);
            background-size: 24px 24px;
            background-attachment: fixed;
        }
        html { scroll-behavior: smooth; }
        
        h1, h2, h3, .logo { 
            font-family: 'Chakra Petch', sans-serif; 
            text-transform: uppercase; 
            font-style: italic;
            letter-spacing: 1px; 
        }

        nav { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 20px 5%; background-color: rgba(9, 9, 11, 0.95); 
            border-bottom: 2px solid var(--gamer-red); 
            position: sticky; top: 0; z-index: 100;
            backdrop-filter: blur(8px);
        }
        .logo { font-size: 1.8rem; font-weight: 700; color: #fff; text-decoration: none; }
        .nav-links a { 
            color: var(--text-muted); text-decoration: none; margin-left: 30px; 
            font-weight: 600; text-transform: uppercase;
            font-family: 'Chakra Petch', sans-serif; font-size: 1.1rem; transition: color 0.2s ease; 
        }
        .nav-links a:hover { color: var(--gamer-red); }

        .hero { 
            text-align: center; padding: 80px 20px 40px; 
            background: linear-gradient(135deg, rgba(255, 42, 42, 0.1) 0%, var(--bg-base) 100%);
            border-bottom: 1px solid var(--border-color);
        }
        .hero h1 { font-size: 3.5rem; margin-bottom: 10px; color: #ffffff; line-height: 1.1; }
        .hero p { font-size: 1.1rem; max-width: 650px; margin: 0 auto 25px; color: var(--text-muted); }
        
        .btn { 
            padding: 14px 32px; text-decoration: none; font-family: 'Chakra Petch', sans-serif; 
            font-weight: 700; font-size: 1.1rem; font-style: italic; text-transform: uppercase;
            transition: all 0.2s ease; display: inline-block; cursor: pointer; border: none;
            clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        }
        .btn-back { background-color: #3f3f46; color: #fff; margin-bottom: 20px; }
        .btn-back:hover { background-color: #52525b; transform: scale(1.05); }
        
        .btn-download { background-color: var(--gamer-red); color: #fff; }
        .btn-download:hover { background-color: var(--gamer-red-dark); transform: scale(1.05); }

        section { padding: 60px 5%; max-width: 1200px; margin: 0 auto; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }
        
        .card { 
            background-color: var(--bg-surface); padding: 35px 30px; 
            border: 1px solid var(--border-color); border-left: 4px solid var(--gamer-red);
            transition: all 0.3s ease; position: relative; 
        }
        .card:hover { 
            transform: translateY(-5px); box-shadow: 0 10px 30px rgba(255, 42, 42, 0.1); border-color: #3f3f46;
        }
        .card h3 { color: #fff; margin-bottom: 15px; font-size: 1.5rem; }
        .card p { color: var(--text-muted); margin-bottom: 25px; min-height: 60px; }

        footer { 
            text-align: center; padding: 40px; background-color: var(--bg-surface); 
            font-size: 0.95rem; color: var(--text-muted); border-top: 1px solid var(--border-color); 
        }
        footer p { margin-bottom: 10px; }

        @media (max-width: 768px) {
            nav { flex-direction: column; gap: 15px; }
            .nav-links a { margin: 0 15px; }
            .hero h1 { font-size: 2.5rem; }
        }
    </style>
</head>
